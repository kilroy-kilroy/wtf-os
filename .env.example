# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-... # For Visibility Engine (search-grounded AI analysis)

# Data Enrichment (Discovery Lab)
INSTANTLY_API_KEY=your-instantly-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
APIFY_API_KEY=your-apify-api-key

# Bright Data (Discovery Lab Pro - LinkedIn scraping, Google SERP, ChatGPT)
BRIGHT_DATA_API=your-bright-data-api-token
# SERP API uses a separate "zone" (create one in BrightData → Proxies & Scraping → SERP API).
# Without this, Google search-position data is skipped.
BRIGHT_DATA_SERP_ZONE=your-serp-zone-name

# Email
RESEND_API_KEY=re_...
EMAIL_FROM=calllab@yourdomain.com

# Email Marketing (Loops.so)
LOOPS_API_KEY=your-loops-api-key

# Newsletter (Beehiiv)
BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUBLICATION_ID=your-beehiiv-publication-id

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Call Lab Pro
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_TEAM=price_...
# Discovery Lab Pro
STRIPE_PRICE_DISCOVERY_SOLO=price_...
STRIPE_PRICE_DISCOVERY_TEAM=price_...
# Visibility Lab Pro
STRIPE_PRICE_VISIBILITY_SOLO=price_...
STRIPE_PRICE_VISIBILITY_TEAM=price_...
# SalesOS Pro Bundle (Call Lab Pro + Discovery Lab Pro)
STRIPE_PRICE_BUNDLE_SOLO=price_...
STRIPE_PRICE_BUNDLE_TEAM=price_...
# GrowthOS Pro Bundle (Call Lab Pro + Discovery Lab Pro + Visibility Lab Pro)
STRIPE_PRICE_GROWTHBUNDLE_SOLO=price_...
STRIPE_PRICE_GROWTHBUNDLE_TEAM=price_...

# Zoom Integration
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_WEBHOOK_SECRET=your-zoom-webhook-secret

# Firma (e-signature) — Contract Generator
# Put real (rotated) values in .env.local, never here. FIRMA_ENV selects which key lib/firma.ts uses.
FIRMA_API_KEY_TEST=firma_test_xxxxxxxx
FIRMA_API_KEY_LIVE=firma_live_xxxxxxxx
FIRMA_ENV=test            # 'test' | 'live'
FIRMA_WEBHOOK_SECRET=your-firma-webhook-secret

# Cron Jobs
CRON_SECRET=your-cron-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Copper CRM (contract autofill, lead sync)
COPPER_API=your-copper-api-key
COPPER_API_EMAIL=you@example.com
